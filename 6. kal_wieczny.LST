0C096h D7         U4B:                  RST       CLR
0C097h 62                               DEFB      62H
0C098h 2110FE                           LD        HL,DATA_M      ;Zadana data
0C09Bh CD2512                           CALL      CZASK          ;Wysw. MIES/DZIEN np. 5  09 na PWYS 63
0C09Eh CF         CZEK:                 RST       TI1            ;                  " 5 09 So"
0C09Fh FE11                             CP        11H            ;SPAC ?
0C0A1h CA00C0                           JP        Z,UD           ;Powtorzenie
0C0A4h D7                               RST       CLR
0C0A5h 62                               DEFB      62H
