00000h                                            
00000h            PRINT:                EQU       01D4H          ; wyświetla tekst wg (HL), + PWyśw np. CD D4 01 44
00000h            KO3:                  EQU       0A23H          ; adres komunikatu "ERROR"
00000h            CLR:                  EQU       10H            ; czyszczenie wyswietlacza
00000h            CO:                   EQU       01E0H          ;
00000h            EXPRW:                EQU       19B4H          ; j.w. ale tylko cyfry dziesietne
00000h            LCI:                  EQU       0FFE8H         ; liczenie do tylu, -1 co 2 ms
00000h            CZASK:                EQU       1225H          ; Wysw. MIES/DZIEN np. 5  09 na PWYS 63
00000h            TI1:                  EQU       8
00000h            LADR:                 EQU       20H            ;wyswietlenie HL w postaci 4. liczby
00000h            TABM:                 EQU       32DH           ; tabela ograniczen miesiecy
00000h            TABD:                 EQU       123FH          ; tabl. dni, symbole literowe, np. PN, WT CA88
00000h            WYSKOM:               EQU       1217H          ; procedura wysw. dnia tyg. z CA88
00000h            DATA_M:               EQU       0FE10H         ; pamiec pobranej daty
00000h            DATA_W:               EQU       0FE20H         ; wzorzec daty do obiczen dnia tygodnia
00000h                                            
00000h                                                           ;  - eliminacja dni 5.10.1582 -14.10.1582 - zmiana kalendarza na gregorianski
00000h                                                           ; uwzglednia tez lata nieprzestepne: 1700, 1800, 1900, 2100                          
00000h                                            
00000h                                                           ; kalendarz wyswietla: m-c, dzien, dzien tygodnia,= lub G to rok
00000h                                                           ;[rok] [.] [m-c] [dzien] [=]
00000h                                            
00000h                                                           ; kalendarz wieczny,  wylicza dzien tygodnia wg zadanej daty
00000h                                                           ; bazowalem na kalendarzu wg S. Gardynika, eleminujac niewielkie bledy w nim zawarte, przy
00000h                                                           ; wyliczaniu dnia tygodnia
00000h                                                           ; Oblicza i wyswietla dzien tygodnia w postaci
00000h                                                           ; symbolicznej /PN, WT itd/ dla lat od 1 do 9999 r., nie bylo roku 0000 /SK/
00000h                                                           ; #d[ROK][.][MIESIAC][.][DZIEN MIES][=]
00000h                                                           ; kazdy nastepny rok ZWIEKSZA dzien tygodnia o 1, jesli rok przestepny to o 2
00000h                                                           ; kazde stulecie ZMNIEJSZA dzien tygodnia o 1 ; jesli przestepny to o 2
00000h                                                           ; np. 1.1.1999.to piatek, 1.1.2000 to  sobota, 1.1.2001 - poniedzialek, a 1.1.2002 to wtorek
00000h                                                           ; 1.1.1583 to sobota / brak dni 5-14.10.1582 !!! zmiana kalendarza na gregorianski
00000h                                                           ; 15.7.1410-bitwa pod Grunwaldem to wtorek
00000h                                                           ; upadek Konstantynopola 29.5.1453 wtorek
00000h                                                           ; lata podzielne przez 4 beda przestepne, z wyjatkiem
00000h                                                           ; tych niepodzielnych przez 400 (lata 1600, 2000, 2400 itd beda w kalendarzu
00000h                                                           ; gregorianskim przestepne, a 1700, 1800, 1900, 2100, 2300 itd nie).
00000h                                                           ; przy sprawdzaniu poprawnosci obliczen bazowalem na programie K. Borkowskiego z UMK Torun
00000h                                                           ; https://www.astro.uni.torun.pl/~kb/Efemerydy/JulianDay.htm
00000h                                                           ; 1.1.1600 - sobota
00000h                                                           ; 1.1.1700 - piatek
00000h                                                           ; 1.1.1800 - sroda
00000h                                                           ; 1.1.1900 - poniedz
00000h                                                           ; 1.1.2000 - sobota
00000h                                            
00000h                                  ORG       #C000          ; oryginal programu z C800 /MIK 11 str. 161, teraz po moich przerobkach
0C000h 21EFC1     UD:                   LD        HL,WZOR_DR1    ; wzorzec daty 1.1.0001 to sobota lub 1.1.1583 to sobota
0C003h 1120FE                           LD        DE,DATA_W      ; wzor daty w RAM
0C006h 010800                           LD        BC,8
0C009h EDB0                             LDIR      
0C00Bh 21FBC1                           LD        HL,R_R
0C00Eh CDD401                           CALL      PRINT
0C011h 80                               DEFB      #80
0C012h 060A                             LD        B,10
0C014h CD7DC0                           CALL      U4X            ; opoznienie ok. 1 sek
0C017h            UD1X:                           
0C017h D7                               RST       CLR
0C018h 80                               DEFB      80H
0C019h 0E0D                             LD        C,0DH          ;Nr zlecenia
0C01Bh CDE001                           CALL      CO
0C01Eh 17                               DEFB      17H
0C01Fh 0E03                             LD        C,3            ;3 parametry
0C021h CDB419                           CALL      EXPRW          ;Tylko cyfr. dziesietne
0C024h 40                               DEFB      40H
0C025h 2110FE                           LD        HL,DATA_M      ;Pamiec daty
0C028h D1                               POP       DE
0C029h 73                               LD        (HL),E         ;Dzien miesiaca
0C02Ah D1                               POP       DE
0C02Bh 23                               INC       HL
0C02Ch 73                               LD        (HL),E         ;Miesiac
0C02Dh E1                               POP       HL
0C02Eh 2212FE                           LD        (DATA_M+2),HL  ;Rok zadany
0C031h 7C                               LD        A,H            ; zapamietaj stulecie do wysw. daty
0C032h F5                               PUSH      AF
0C033h CDCEC1                           CALL      KOR_R          ; korekcja roku, c0 400 lat sa tre same dni tygodnia,
0C036h                                                           ; wiec np. zamien rok 20xx na 16xx
0C036h E5                               PUSH      HL
0C037h CD7AC1                           CALL      SPR5_14        ; czy data lezy miedzy 5 - 14 pazdzier 1582 blad
0C03Ah B7                               OR        A              ; CY=0 wazne !!
0C03Bh 218215                           LD        HL,#1582
0C03Eh ED5B12FE                         LD        DE,(DATA_M+2)  ; rok zadany
0C042h ED52                             SBC       HL,DE
0C044h E1                               POP       HL
0C045h 300A                             JR        NC,UD1A        ; rok zadany <= od 1582, wzor daty 1.1.0001, sobota
0C047h                                                           ; rok zadany >= 1583
0C047h ED4BF5C1                         LD        BC,(WZOR_DR1+6); C=6 -sobota, B = 1- bo do nast. roku przest. zostal 1. rok
0C04Bh ED5BF3C1                         LD        DE,(WZOR_DR1+4);1583 r.
0C04Fh 1808                             JR        UD1A1
0C051h            UD1A:                                          ; do 4.10.1582 dni tygodnia beda prawidlowe wg ponizszego wzoru 
0C051h ED4BF1C1                         LD        BC,(WZOR_DR1+2);C=6 ;B=3 bo nastepny rok przestep za 3 lata, C=6 - sobota
0C055h ED5BEFC1                         LD        DE,(WZOR_DR1)  ; rok odniesienia 0001
0C059h 3A13FE     UD1A1:                LD        A,(DATA_M+3)   ; stulecie
0C05Ch FE20                             CP        #20
0C05Eh 3808                             JR        C,UD1          ; stulecie < 20
0C060h ED4BF9C1                         LD        BC,(WZOR_DR1+10)
0C064h ED5BF7C1                         LD        DE,(WZOR_DR1+8)
0C068h CDB3C0     UD1:                  CALL      SROK           ; szukanie roku
0C06Bh ED5B10FE                         LD        DE,(DATA_M)    ; E - dzien, D - miesiac
0C06Fh CDE6C0                           CALL      SDZIEN         ; szukanie dnia
0C072h 2810                             JR        Z,U4A          ; dzien znaleziono
0C074h                                                           ;Error - data falszywa
0C074h 21230A     UD1_ERR:              LD        HL,KO3         ;Error
0C077h CDD401                           CALL      PRINT
0C07Ah 50                               DEFB      50H
0C07Bh                                                           ;Opoznienie 0.7 sek
0C07Bh 0607                             LD        B,7
0C07Dh CD3AC1     U4X:                  CALL      DEL100
0C080h 10FB                             DJNZ      U4X
0C082h 1893                             JR        UD1X
0C084h                                                           ;Wyswietlenie znalezionego dnia
0C084h                                                           ;WE: C - dzien tygodnia (1-Pn,2-Wt,3-Sr....)
0C084h            U4A:                            
