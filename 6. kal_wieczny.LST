0C1CEh                                                           ; w kalendarzu gregorianskim, co 400 lat dni tygodnia
0C1CEh                                                           ; w roku sa identyczne ! np. w 1600 - 2000 - 2400,
0C1CEh                                                           ; 1700 - 2100 - 2500 itd, 1800 - 2200 - 2600 itd, 1900 - 2300 - 2700 itd
0C1CEh                                                           ; i to wykorzystamy do obliczen lat do 9999 ! czy swiat bedzie jeszcze istnial ???
0C1CEh                                            
0C1CEh            KOR_R:                                         ; sprawdz rok i skoryguj zadany rok na czas obl. procedury <SROK>   
0C1CEh 3A13FE                           LD        A,(DATA_M+3)   ; stulecie
0C1D1h FE20                             CP        #20
0C1D3h D8                               RET       C
0C1D4h            KOR_R1:                         
0C1D4h D604                             SUB       4              ; "400" lat
0C1D6h 27                               DAA       
0C1D7h FE04                             CP        4
0C1D9h 30F9                             JR        NC,KOR_R1
0C1DBh                                                           ; A - ile dodac do 16xx i ten rok wprowadz jako zadany
0C1DBh 0E16                             LD        C,#16
0C1DDh 81                               ADD       A,C
0C1DEh 27                               DAA       
0C1DFh 3213FE                           LD        (DATA_M+3),A
0C1E2h C9                               RET       
0C1E3h                                            
0C1E3h                                                           ;Opoznienie ok. 10 msek
0C1E3h 3E05       DEL10:                LD        A,5            ;5*2msek=10msek
0C1E5h 32E8FF                           LD        (LCI),A
0C1E8h 3AE8FF     DE11:                 LD        A,(LCI)
0C1EBh B7                               OR        A
0C1ECh 20FA                             JR        NZ,DE11
0C1EEh C9                               RET       
0C1EFh                                            
0C1EFh 0100060383 WZOR_DR1:             DEFB      1,0,6,3,83H,15H,6,1,0,20H,6,4
0C1FBh                                                           ; komunikaty na CA80
0C1FBh 505050D0   R_R:                  DEFB      #50,#50,#50,#D0; r r r r. -rok
0C1FFh 5EDE       DD:                   DEFB      #5E,#DE        ;          ; d d.     - dzien
0C201h 54D4FF     MM:                   DEFB      #54,#D4,255    ; nn.      - miesiac 
0C204h DDE2                             DEFB      0DDH,0E2H      ; DDE2 - marker nazwy programu, jesli mamy LCD i magazyn programow np. 
0C206h                                                           ; https://github.com/Roman-tor/programy-magazyn-w-CA80/blob/main/1.README.md
0C206h 204B414C45                       DEFM      " KALENDARZ WIECZNY",255; nazwa programu
0C219h                                            
