0C0B3h                                                           ; 0001.01.01 - SOBOTA - dzien odniesienia
0C0B3h                                                           ; 0001 - rok nieprzestepny, 1700, 1800, 1900, 2100, 2300, 2500 tez
0C0B3h                                                           ; 365 dni - rok normalny
0C0B3h                                                           ; 366 dni - rok przestepny co 4 lata
0C0B3h                                                           ; 52tygodnie * 7 = 364 dni
0C0B3h                                                           ; WE: DATA+2 - etykieta wskazujaca zadany rok
0C0B3h                                                           ; HL = zadany rok
0C0B3h                                                           ; WY: C - dzien tygodnia w dniu 1 stacznia
0C0B3h                                                           ;    B = co 4. lata - rok przestepny
0C0B3h            SROK:                           
