0C0C0h 27                               DAA       
0C0C1h 57                               LD        D,A
0C0C2h 2A12FE                           LD        HL,(DATA_M+2)  ;Rok zadany
0C0C5h 0C                               INC       C              ;Rok normalny
0C0C6h 79                               LD        A,C
0C0C7h FE08                             CP        8
0C0C9h 3802                             JR        C,P2A
0C0CBh 0E01                             LD        C,1            ;Poniedzialek
0C0CDh 05         P2A:                  DEC       B              ;Czy rok przestepny ?
0C0CEh 2010                             JR        NZ,P2C         ;Nie
0C0D0h 0604                             LD        B,4            ;Rok przestepny
0C0D2h B7                               OR        A              ;CY=0
0C0D3h ED52                             SBC       HL,DE
0C0D5h C8                               RET       Z              ;Rok przestepny
0C0D6h 0C                               INC       C
0C0D7h 79                               LD        A,C            ;Dzien tygodnia
0C0D8h FE08                             CP        8
0C0DAh 3802                             JR        C,P2B
0C0DCh 0E01                             LD        C,1            ;Poniedzialek
0C0DEh 18D8       P2B:                  JR        P0001          ;Nastepny rok
0C0E0h B7         P2C:                  OR        A              ;CY=0
0C0E1h ED52                             SBC       HL,DE
